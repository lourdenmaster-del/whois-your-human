{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ligs.io/ioc-lite.schema.json",
  "title": "IOC Lite machine response",
  "type": "object",
  "additionalProperties": false,
  "required": ["ioc_version", "type", "data", "agent_rules"],
  "properties": {
    "ioc_version": {
      "$ref": "#/$defs/ioc_version"
    },
    "type": {
      "type": "string",
      "const": "ioc_lite"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archetype", "iocFree"],
      "properties": {
        "archetype": {
          "type": "string",
          "description": "Lowercase IOC archetype key derived from birthdate."
        },
        "iocFree": {
          "type": "string",
          "description": "Truncated initial operating conditions block (free tier)."
        }
      }
    },
    "agent_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upgrade_condition",
        "max_upgrade_requests_per_session",
        "fallback_behavior",
        "inaccuracy_definition"
      ],
      "properties": {
        "upgrade_condition": {
          "type": "string",
          "description": "When the agent may request a full IOC upgrade."
        },
        "max_upgrade_requests_per_session": {
          "type": "integer",
          "minimum": 0
        },
        "fallback_behavior": {
          "type": "string",
          "description": "Behavior when upgrade is unavailable or declined."
        },
        "inaccuracy_definition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "ioc_version": {
      "description": "Machine protocol version; shared with ioc-full.schema.json.",
      "type": "string",
      "const": "0.3"
    }
  }
}
