# Copy to .env.local and fill in values.
# Required for Beauty form, demo, and image generation:

OPENAI_API_KEY=sk-...

# Optional:
# NEXT_PUBLIC_DRY_RUN=1   # When "1" or "true", client never sends generate requests (LigsStudio shows Dry Run Preview + banner)
# NEXT_PUBLIC_FAKE_PAY=1 # When "1" or "true", CTA bypasses Stripe; sets unlock + redirect to /beauty/start (marketing testing)
# NEXT_PUBLIC_TEST_MODE=1 # When "1" or "true", dry image gen, deterministic overlay; Blob writes ON unless DISABLE_BLOB_WRITES=1; logs "TEST MODE" in console
# DISABLE_BLOB_WRITES=1   # Optional: when "1" or "true", disable Blob writes even in TEST_MODE
# BEAUTY_SECRET=                    # If set, some flows may require this header
# VERCEL_URL=                       # Set automatically on Vercel
# BLOB_READ_WRITE_TOKEN=            # For persisting reports (Vercel Blob)
# ALLOW_EXTERNAL_WRITES=true        # REQUIRED for LIVE: real DALL·E/image/compose/Blob calls (LigsStudio, exemplars)
# ALLOW_EXTERNAL_WRITES_IN_DEV=1    # Alternative in dev: same as ALLOW_EXTERNAL_WRITES for local testing
# ALLOW_FORCE_LIVE=true             # When "true", X-Force-Live: 1 header can bypass dry-run (default: false)
# ALLOW_PREVIEW_LIVE_TEST=1         # When "1", dev routes (preflight, beauty-live-once, verify-report) work on Vercel Preview
# NEXT_PUBLIC_SHOW_DEV_CONTROLS=1   # When "1", LIVE TEST RUN button shows on /beauty?dev=1 even on Preview (NODE_ENV=production)
# STRIPE_SECRET_KEY=      # For Beauty checkout
# STRIPE_WEBHOOK_SECRET=  # For Stripe webhooks
# LIGS_API_OFF=1          # Production kill-switch: set to 1 to block sensitive APIs (503 maintenance)
